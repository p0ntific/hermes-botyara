# --- Telegram аккаунты -------------------------------------------------------
# Основной способ: accounts.yaml (см. accounts.example.yaml) + ACCOUNTS_FILE.
# Значения ${VAR} в accounts.yaml подставляются из этого файла.
ACCOUNTS_FILE=accounts.yaml

# Legacy-режим одного аккаунта (работает, если accounts.yaml отсутствует)
API_ID=
API_HASH=
SESSION=

# Чат, куда сканер льет лидов
TARGET_CHAT=-1003447031372

# --- Уведомления менеджеру (@BotFather) ---------------------------------------
BOT_TOKEN=
BOT_CHAT_ID=-1005316760602

# Прокси по умолчанию (пусто = без прокси; на аккаунт можно задать свой в accounts.yaml)
PROXY_URL=socks5h://127.0.0.1:9051

# --- LLM ----------------------------------------------------------------------
# Провайдер: openrouter | yandex | openai | custom.
# Если не задан, выбирается по наличию ключа (OPENROUTER_API_KEY -> openrouter, ...).
LLM_PROVIDER=openrouter

# OpenRouter (https://openrouter.ai/keys). Модель по умолчанию:
# anthropic/claude-sonnet-4.5 - сильный русский, точное следование инструкциям,
# надежный JSON для классификатора. Список актуальных слагов: openrouter.ai/models
# (там же anthropic/claude-haiku-4.5 подешевле, deepseek/gemini для экспериментов).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
# OPENROUTER_SITE_URL=https://pulsar-tg.ru/
# OPENROUTER_APP_NAME=hermes-botyara

# Yandex Cloud (использовался ранее; остается как провайдер и как fallback)
YANDEX_CLOUD_FOLDER=
YANDEX_CLOUD_API_KEY=
YANDEX_CLOUD_MODEL=yandexgpt-5.1/latest

# OpenAI (опционально)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Custom: любой OpenAI-совместимый сервер (vLLM, Ollama, ...)
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=
# LLM_MODEL=qwen2.5:32b

# Глобальный override модели выбранного провайдера
# LLM_MODEL=anthropic/claude-sonnet-4.5

# Пер-задачные override'ы - разные модели на разные стадии пайплайна:
# LLM_MODEL_PITCH=anthropic/claude-sonnet-4.5
# LLM_MODEL_CLASSIFY=anthropic/claude-haiku-4.5
# LLM_MODEL_REPLY=anthropic/claude-sonnet-4.5
# LLM_PROVIDER_CLASSIFY=yandex

# Fallback-провайдер: если основной лег, вызовы уходят сюда
LLM_FALLBACK_PROVIDER=yandex
# LLM_FALLBACK_MODEL=

# --- Поведение ------------------------------------------------------------------
MANAGER_USERNAME=MaksIgitov
PRODUCT_URL=https://pulsar-tg.ru/
PRODUCT_NAME=Пульсар
COLD_DM_DAILY_LIMIT=5
SEND_DELAY_MIN_SECONDS=120
SEND_DELAY_MAX_SECONDS=600
GENERIC_LIMIT_COOLDOWN_SECONDS=18000
FLOOD_WAIT_EXTRA_SECONDS=300
INCOMING_REPLY_DEBOUNCE_SECONDS=20
MAX_PITCH_ATTEMPTS=5

# --- Хранилище -------------------------------------------------------------------
# SQLite: очередь лидов, транскрипты, состояние аккаунтов, лог LLM-вызовов
HERMES_DB=hermes.db
# Старый JSON: при первом запуске импортируется в SQLite автоматически
DB_FILE=mtproto_leads.json
